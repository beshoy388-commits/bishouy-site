# Database connection string
# Example (Local SQLite): file:sqlite.db
# Example (Remote LibSQL): libsql://your-db.turso.io
DATABASE_URL=file:sqlite.db
DATABASE_AUTH_TOKEN=

# App Configuration
NODE_ENV=development
APP_URL=https://bishouy.com
JWT_SECRET=your_jwt_secret_key_here

# AI & API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Brevo Email Service 
BREVO_API_KEY=your_brevo_api_key_here

# User/Admin Configuration
# Owner email automatically gets admin role
OWNER_EMAIL=beshoy4703088@icloud.com
ADMIN_2FA_OVERRIDE_CODE=your_hashed_override_code_here

# Flags
DISABLE_RSS_SYNC=false
