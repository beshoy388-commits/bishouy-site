# Database connection string (MySQL is required)
# Example: mysql://user:password@localhost:3306/bishouy
DATABASE_URL=

# App ID and Secrets
VITE_APP_ID=
JWT_SECRET=super_secret_jwt_key_here

# OAuth Configuration (if applicable)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Manus Forge API (Storage)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Brevo Email Service (transactional emails)
BREVO_API_KEY=

# Owner/Admin email — this account automatically gets admin role
OWNER_EMAIL=

# Base URL of the application (e.g., https://bishouy.com or http://localhost:3000)
APP_URL=
